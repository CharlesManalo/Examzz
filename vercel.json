{
  "version": 2,
  "buildCommand": "cd app && npm install && npm run build",
  "outputDirectory": "app/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/main.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/main.py": {
      "runtime": "python3.9"
    }
  }
}
