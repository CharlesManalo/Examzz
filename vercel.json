{
  "version": 2,
  "buildCommand": "cd app && npm install && npm run build",
  "outputDirectory": "app/dist",
  "functions": {
    "api/main.py": {
      "runtime": "python3.12",
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/app/$1" }
  ]
}
