{
  "buildCommand": "cd app && npm install && npm run build",
  "outputDirectory": "app/dist",
  "functions": {
    "api/process.py": {
      "runtime": "python3.12",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/process.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
