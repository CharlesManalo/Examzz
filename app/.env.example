# StudyQuiz Pro Environment Variables

# App Configuration
VITE_APP_NAME=StudyQuiz Pro
VITE_APP_URL=https://studyquiz.netlify.app

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdef
STRIPE_SECRET_KEY=sk_test_51234567890abcdef
STRIPE_WEBHOOK_SECRET=whsec_1234567890abcdef

# Database Configuration (if using Supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Analytics (Google Analytics 4)
# Get your ID from: https://analytics.google.com
# VITE_GA_ID=G-XXXXXXXXXX

# Google AdSense
# Get your client ID from: https://www.google.com/adsense
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Feature Flags
VITE_MAX_FILE_SIZE=26214400
VITE_MAX_FILES=15
VITE_ENABLE_PREMIUM=true
VITE_ENABLE_ANALYTICS=true

# Admin Configuration
VITE_ADMIN_EMAIL=admin@studyquiz.com

# Environment
VITE_APP_ENV=development
